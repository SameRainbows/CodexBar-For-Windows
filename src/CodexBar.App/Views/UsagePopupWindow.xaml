<Window x:Class="CodexBar.App.Views.UsagePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodexBar.App.Views"
        Title="CodexBar"
        Width="380" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="BgBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A4C"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E8"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9090A8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C6FF0"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#4ADE80"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#FBBF24"/>
        <SolidColorBrush x:Key="RedBrush" Color="#F87171"/>
        <x:Static Member="local:ProviderStatusTextConverter.Instance" x:Key="ProviderStatusTextConverter"/>
        <x:Static Member="local:ProviderStatusBrushConverter.Instance" x:Key="ProviderStatusBrushConverter"/>
        <x:Static Member="local:EmptyStringToVisibilityConverter.Instance" x:Key="EmptyStringToVisibilityConverter"/>
        <x:Static Member="local:CollectionHasItemsToVisibilityConverter.Instance" x:Key="CollectionHasItemsToVisibilityConverter"/>
        <x:Static Member="local:CollectionEmptyToVisibilityConverter.Instance" x:Key="CollectionEmptyToVisibilityConverter"/>
        <x:Static Member="local:ModelQuotaResetTextConverter.Instance" x:Key="ModelQuotaResetTextConverter"/>
        <x:Static Member="local:RemainingPercentBrushConverter.Instance" x:Key="RemainingPercentBrushConverter"/>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎚️" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CodexBar" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                                Content="🔄" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Cursor="Hand" Padding="6,2"
                                ToolTip="Refresh Now"/>
                        <Button x:Name="SettingsButton" Click="SettingsButton_Click"
                                Content="⚙️" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Cursor="Hand" Padding="6,2"
                                ToolTip="Settings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Provider Cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl x:Name="ProviderList" ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBgBrush}"
                                    CornerRadius="8" Margin="4,4" Padding="12,10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <!-- Provider Name + Status -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="11"
                                                   Foreground="{Binding Status, Converter={StaticResource ProviderStatusBrushConverter}}"
                                                   Text="{Binding Status, Converter={StaticResource ProviderStatusTextConverter}}"/>
                                    </Grid>

                                    <TextBlock Text="{Binding Snapshot.ActionHint}"
                                               FontSize="10"
                                               Foreground="{StaticResource YellowBrush}"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding Snapshot.ActionHint, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Snapshot.ErrorMessage}"
                                               FontSize="10"
                                               Foreground="{StaticResource RedBrush}"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding Snapshot.ErrorMessage, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>

                                    <!-- Detailed model quotas (AntiGravity-style) -->
                                    <StackPanel Visibility="{Binding Snapshot.ModelQuotas, Converter={StaticResource CollectionHasItemsToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding Snapshot.ModelQuotas}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <Grid Margin="0,0,0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding ModelName}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ResetsAt, Converter={StaticResource ModelQuotaResetTextConverter}}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </Grid>
                                                        <Grid Height="6" Margin="0,0,0,2">
                                                            <Border Background="#1A1A2A" CornerRadius="3"/>
                                                            <Border CornerRadius="3" HorizontalAlignment="Left"
                                                                    Background="{Binding RemainingPercent, Converter={StaticResource RemainingPercentBrushConverter}}">
                                                                <Border.Width>
                                                                    <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                                        <Binding Path="RemainingPercent" FallbackValue="0"/>
                                                                        <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Grid>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding RemainingPercent, StringFormat={}{0:F0}% remaining}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Badge}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource YellowBrush}"
                                                                       Visibility="{Binding Badge, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Generic provider quotas -->
                                    <StackPanel Visibility="{Binding Snapshot.ModelQuotas, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                                        <!-- Session Bar -->
                                        <TextBlock Text="{Binding Snapshot.SessionQuota.Label, FallbackValue='Session'}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,3"/>
                                        <Grid Height="8" Margin="0,0,0,2">
                                            <Border Background="#1A1A2A" CornerRadius="4"/>
                                            <Border CornerRadius="4" HorizontalAlignment="Left"
                                                    Background="{StaticResource AccentBrush}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                        <Binding Path="Snapshot.SessionQuota.RemainingPercent" FallbackValue="0"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                            <TextBlock.Text>
                                                <Binding Path="Snapshot.SessionQuota" FallbackValue="No data"
                                                         Converter="{x:Static local:QuotaToTextConverter.Instance}"/>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <!-- Weekly Bar -->
                                        <TextBlock Text="{Binding Snapshot.WeeklyQuota.Label, FallbackValue='Weekly'}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,3"/>
                                        <Grid Height="6" Margin="0,0,0,2">
                                            <Border Background="#1A1A2A" CornerRadius="3"/>
                                            <Border CornerRadius="3" HorizontalAlignment="Left"
                                                    Background="{StaticResource GreenBrush}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                        <Binding Path="Snapshot.WeeklyQuota.RemainingPercent" FallbackValue="0"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="Snapshot.WeeklyQuota" FallbackValue="No data"
                                                         Converter="{x:Static local:QuotaToTextConverter.Instance}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding LastRefreshText}"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
