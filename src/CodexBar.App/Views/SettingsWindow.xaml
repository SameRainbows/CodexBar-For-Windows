<Window x:Class="CodexBar.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar Settings"
        Width="400" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E8"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9090A8"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A4C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C6FF0"/>

        <Style x:Key="ToggleStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- Poll Interval -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Refresh Interval" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <ComboBox x:Name="IntervalCombo" SelectionChanged="IntervalCombo_SelectionChanged"
                      Width="200" HorizontalAlignment="Left">
                <ComboBoxItem Content="1 minute" Tag="60"/>
                <ComboBoxItem Content="2 minutes" Tag="120"/>
                <ComboBoxItem Content="5 minutes" Tag="300" IsSelected="True"/>
                <ComboBoxItem Content="15 minutes" Tag="900"/>
            </ComboBox>
        </StackPanel>

        <!-- General -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="General" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <CheckBox x:Name="StartWithWindowsCheck"
                      Content="  Start with Windows"
                      Style="{StaticResource ToggleStyle}"
                      Checked="StartWithWindowsCheck_Changed"
                      Unchecked="StartWithWindowsCheck_Changed"/>
            <CheckBox x:Name="NotifyOnExhaustionCheck"
                      Content="  Notify when quota is low/exhausted"
                      Style="{StaticResource ToggleStyle}"
                      Checked="NotifyOnExhaustionCheck_Changed"
                      Unchecked="NotifyOnExhaustionCheck_Changed"/>
        </StackPanel>

        <!-- Provider Toggles -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="Providers" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="8"
                    Padding="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel x:Name="ProviderToggles"/>
            </Border>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Run Diagnostics" Click="DiagnosticsButton_Click"
                    Width="140" Height="32" Margin="0,0,8,0"
                    Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="13" Cursor="Hand"/>
            <Button Content="Close" Click="CloseButton_Click"
                    Width="100" Height="32"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
