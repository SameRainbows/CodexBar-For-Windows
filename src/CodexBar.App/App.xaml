<Application x:Class="CodexBar.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ContextMenu x:Key="TrayContextMenu">
            <MenuItem Header="🔄 Refresh Now" Click="TrayRefresh_Click"/>
            <Separator/>
            <MenuItem Header="🩺 Diagnostics" Click="TrayDiagnostics_Click"/>
            <Separator/>
            <MenuItem Header="⚙️ Settings" Click="TraySettings_Click"/>
            <Separator/>
            <MenuItem Header="❌ Exit" Click="TrayExit_Click"/>
        </ContextMenu>

        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="CodexBar — Loading..."
                        ContextMenu="{StaticResource TrayContextMenu}"
                        TrayLeftMouseDown="TrayIcon_TrayLeftMouseDown"/>
    </Application.Resources>
</Application>
